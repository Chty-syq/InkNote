{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "逸仙笔记",
  "version": "0.2.10",
  "identifier": "com.codex.inknote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:bundle",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "逸仙笔记",
        "width": 1600,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/workspace/apps/web/public/**",
          "$APPDATA/workspace/content/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../web/dist/index.html": "web-dist/index.html",
      "../../web/dist/404.html": "web-dist/404.html",
      "../../web/dist/assets/": "web-dist/assets/",
      "../../web/dist/blog-avatar.jpg": "web-dist/blog-avatar.jpg",
      "../../web/dist/blog-header-bg.png": "web-dist/blog-header-bg.png",
      "../../../content/": "default-content/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": [
        "https://github.com/Chty-syq/InkNote/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
