{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InkNote",
  "version": "0.1.0",
  "identifier": "com.codex.inknote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:bundle",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "InkNote - 伪手写笔记本",
        "width": 1600,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": {
      "../../web/dist/": "web-dist/",
      "../../../content/": "default-content/"
    }
  }
}
